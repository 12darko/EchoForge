<Window x:Class="EchoForge.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EchoForge.WPF.ViewModels"
        xmlns:views="clr-namespace:EchoForge.WPF.Views"
        xmlns:loc="clr-namespace:EchoForge.WPF.Localization"
        Title="EchoForge — AI Music Video Studio"
        Width="1280" Height="800"
        MinWidth="1024" MinHeight="700"
        WindowStartupLocation="CenterScreen"
        Background="#0D1117"
        Icon="pack://application:,,,/Assets/echoforge_icon.ico">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="32"
                      ResizeBorderThickness="6"
                      CornerRadius="0"
                      GlassFrameThickness="0"
                      UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DashboardViewModel}">
            <views:DashboardView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:CreateProjectViewModel}">
            <views:CreateProjectView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ChannelsViewModel}">
            <views:ChannelsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EditorViewModel}">
            <views:EditorView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:YouTubeVideosViewModel}">
            <views:YouTubeVideosView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:LoginViewModel}">
            <views:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <views:UsersView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="32"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar -->
        <Grid Grid.Row="0" Background="#161B22">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- App Icon / Title -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="⚡" FontSize="14" Foreground="#8B5CF6"/>
                <TextBlock Text="EchoForge" Foreground="#8B949E" FontSize="12" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Window Controls (Min, Max, Close) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                <Button Content="-" Width="46" Background="Transparent" Foreground="#8B949E" BorderThickness="0"
                        FontSize="16" FontFamily="Consolas" Cursor="Hand" Click="MinimizeButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#30363D"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="□" Width="46" Background="Transparent" Foreground="#8B949E" BorderThickness="0"
                        FontSize="14" FontFamily="Consolas" Cursor="Hand" Click="MaximizeButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#30363D"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="✕" Width="46" Background="Transparent" Foreground="#8B949E" BorderThickness="0"
                        FontSize="12" FontFamily="Consolas" Cursor="Hand" Click="CloseButton_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#E81123"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Window Content Group -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

        <!-- Entire Window Premium Background -->
        <Border Grid.ColumnSpan="2" Background="{StaticResource PremiumBackgroundBrush}"/>

        <!-- Main Content (renders first, behind sidebar) -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Background="Transparent" Panel.ZIndex="0">
            <ContentControl Content="{Binding CurrentView}">
                <ContentControl.Style>
                    <Style TargetType="ContentControl">
                        <Setter Property="Margin" Value="292,32,32,32"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsLoggedIn}" Value="False">
                                <Setter Property="Margin" Value="0"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ContentControl.Style>
            </ContentControl>
        </Border>

        <!-- Sidebar Navigation (hidden during Login, renders on top) -->
        <Border Grid.Column="0" Background="#F00B0F19" BorderBrush="#15FFFFFF" BorderThickness="0,0,1,0"
                Visibility="{Binding IsLoggedIn, Converter={StaticResource BooleanToVisibilityConverter}}"
                Panel.ZIndex="10">
            <DockPanel>
                <!-- Logo & Brand (TOP) -->
                <StackPanel DockPanel.Dock="Top" Margin="20,28,20,24">
                    <TextBlock Text="⚡ EchoForge" FontSize="24" FontWeight="Bold" Foreground="#8B5CF6"/>
                    <TextBlock Text="AI Content Studio" FontSize="11" Foreground="#8B949E" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- BOTTOM SECTION: Help + Version (MUST be before fill) -->
                <StackPanel DockPanel.Dock="Bottom" Margin="0,0,0,16">
                    <!-- Separator -->
                    <Border Height="1" Background="#15FFFFFF" Margin="16,8,16,12"/>
                    
                    <!-- Settings -->
                    <Button Command="{Binding NavigateToSettingsCommand}" Margin="12,2"
                            Style="{StaticResource NavButton}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙️" FontSize="16" Margin="0,0,14,0"/>
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Nav_Settings]}"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Help -->
                    <Button Command="{Binding ToggleTutorialCommand}" Margin="12,2"
                            Style="{StaticResource NavButton}" Foreground="#3B82F6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💡" FontSize="16" Margin="0,0,14,0"/>
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Nav_Help]}"/>
                        </StackPanel>
                    </Button>
                    
                    <!-- Version -->
                    <TextBlock Text="v2.0.0 — EchoForge" FontSize="10"
                               Foreground="#484F58" HorizontalAlignment="Center" Margin="0,12,0,4"/>
                </StackPanel>

                <!-- MAIN NAV (Fill area — scrollable) -->
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0">
                    <StackPanel Margin="12,0">

                        <!-- ──── Dashboard (standalone) ──── -->
                        <Button Command="{Binding NavigateToDashboardCommand}" Margin="0,2"
                                Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="16" Margin="0,0,14,0"/>
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Nav_Dashboard]}"/>
                            </StackPanel>
                        </Button>

                        <!-- ──── CATEGORY: Music Video ──── -->
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Cat_MusicVideo]}" FontSize="10" FontWeight="Bold" Foreground="#484F58" 
                                   Margin="16,20,0,8"/>
                        
                        <Button Command="{Binding NavigateToCreateCommand}" Margin="0,2"
                                Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✨" FontSize="16" Margin="0,0,14,0"/>
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Nav_NewProject]}"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToChannelsCommand}" Margin="0,2"
                                Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📺" FontSize="16" Margin="0,0,14,0"/>
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Nav_MyChannels]}"/>
                            </StackPanel>
                        </Button>

                        <Button Command="{Binding NavigateToMyVideosCommand}" Margin="0,2"
                                Style="{StaticResource NavButton}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎬" FontSize="16" Margin="0,0,14,0"/>
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Nav_MyVideos]}"/>
                            </StackPanel>
                        </Button>

                        <!-- ──── CATEGORY: Animation (Coming Soon) ──── -->
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Cat_Animation]}" FontSize="10" FontWeight="Bold" Foreground="#484F58" 
                                   Margin="16,20,0,8"/>
                        
                        <Button Margin="0,2" Style="{StaticResource NavButton}" IsEnabled="False" Opacity="0.4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎨" FontSize="16" Margin="0,0,14,0"/>
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Cat_NewAnimation]}"/>
                            </StackPanel>
                        </Button>

                        <Button Margin="0,2" Style="{StaticResource NavButton}" IsEnabled="False" Opacity="0.4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📽️" FontSize="16" Margin="0,0,14,0"/>
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Cat_Storyboard]}"/>
                            </StackPanel>
                        </Button>

                        <!-- ──── CATEGORY: Tools ──── -->
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Cat_Tools]}" FontSize="10" FontWeight="Bold" Foreground="#484F58" 
                                   Margin="16,20,0,8"/>

                        <Button Margin="0,2" Style="{StaticResource NavButton}" IsEnabled="False" Opacity="0.4">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🤖" FontSize="16" Margin="0,0,14,0"/>
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Cat_AIAssistant]}"/>
                            </StackPanel>
                        </Button>

                        <!-- ──── CATEGORY: Admin (only visible for admins) ──── -->
                        <TextBlock Text="ADMİN" FontSize="10" FontWeight="Bold" Foreground="#484F58" 
                                   Margin="16,20,0,8"
                                   Visibility="{Binding IsCurrentUserAdmin, Converter={StaticResource BooleanToVisibilityConverter}}"/>

                        <Button Command="{Binding NavigateToUsersCommand}" Margin="0,2"
                                Style="{StaticResource NavButton}"
                                Visibility="{Binding IsCurrentUserAdmin, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="16" Margin="0,0,14,0"/>
                                <TextBlock Text="Kullanıcılar"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </ScrollViewer>

            </DockPanel>
        </Border>

        <!-- TUTORIAL OVERLAY -->
        <Grid Grid.ColumnSpan="2" Background="#E5000000" Visibility="{Binding IsTutorialVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="999">
            <!-- Click anywhere to close -->
            <Grid.InputBindings>
                <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleTutorialCommand}"/>
            </Grid.InputBindings>
            
            <Border Background="{StaticResource CardDarkBrush}" BorderBrush="{StaticResource AccentPurpleBrush}" BorderThickness="1"
                    CornerRadius="16" Width="500" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="32"
                    Effect="{StaticResource ShadowEffect}">
                <StackPanel>
                    <TextBlock Text="{Binding TutorialIcon}" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding TutorialTitle}" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding TutorialText}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" LineHeight="22" Margin="0,0,0,32"/>
                    
                    <Button Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Btn_GotIt]}" Command="{Binding ToggleTutorialCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center" Padding="32,12" FontSize="14"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- DISCONNECTED OVERLAY -->
        <Grid Grid.ColumnSpan="2" Background="#E50D1117" Visibility="{Binding IsDisconnected, Converter={StaticResource BooleanToVisibilityConverter}}" Panel.ZIndex="1000">
            <Border Background="{StaticResource CardDarkBrush}" BorderBrush="#30363D" BorderThickness="1"
                    CornerRadius="16" Width="480" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="40"
                    Effect="{StaticResource ShadowEffect}">
                <StackPanel>
                    <TextBlock Text="🔌" FontSize="56" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Warning_ConnectionLost], TargetNullValue='Connection Lost'}" 
                               FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Text_ConnectionLostHelper], TargetNullValue='We lost connection to the server. Please check your internet or ensure the server is running.'}" 
                               FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center" LineHeight="22" Margin="0,0,0,32"/>
                    
                    <Button Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Btn_Reconnect], TargetNullValue='Try Reconnect'}" 
                            Command="{Binding ReconnectCommand}" Style="{StaticResource PrimaryButton}" HorizontalAlignment="Center" Padding="48,14" FontSize="14" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>
        </Grid>

        </Grid>
    </Grid>
</Window>
