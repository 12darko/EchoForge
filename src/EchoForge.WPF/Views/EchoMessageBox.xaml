<Window x:Class="EchoForge.WPF.Views.EchoMessageBox"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EchoForge" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Width="480" Height="280" ShowInTaskbar="False">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.25"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <!-- Dark overlay behind card -->
    <Grid>
        <Border Background="#CC000000" CornerRadius="16"/>
        
        <!-- Glass Card -->
        <Border CornerRadius="16" Margin="0" Padding="32" 
                BorderBrush="#30FFFFFF" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F0161B22" Offset="0"/>
                    <GradientStop Color="#E80D1117" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#8B5CF6" Opacity="0.15" BlurRadius="30" ShadowDepth="0"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                    <TextBlock x:Name="IconText" Text="ℹ️" FontSize="28" VerticalAlignment="Center" Margin="0,0,16,0"/>
                    <TextBlock x:Name="TitleText" Text="Message" FontSize="20" FontWeight="Bold" Foreground="#F8FAFC" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Message -->
                <TextBlock Grid.Row="1" x:Name="MessageText" Text="This is a message." 
                           FontSize="14" Foreground="#94A3B8" TextWrapping="Wrap" 
                           LineHeight="22" Margin="0,0,0,24"/>

                <!-- Buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="BtnCancel" Content="Cancel" Visibility="Collapsed"
                            Click="BtnCancel_Click" Margin="0,0,12,0"
                            Padding="28,12" FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                            Background="#2A303C" Foreground="#F8FAFC" BorderThickness="0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="#353B48"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button x:Name="BtnOk" Content="OK" Click="BtnOk_Click"
                            Padding="28,12" FontSize="14" FontWeight="SemiBold" Cursor="Hand"
                            Foreground="White" BorderThickness="0">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#A855F7" Offset="0"/>
                                <GradientStop Color="#6366F1" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
