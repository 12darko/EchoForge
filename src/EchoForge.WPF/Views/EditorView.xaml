<UserControl x:Class="EchoForge.WPF.Views.EditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:dd="urn:gong-wpf-dragdrop"
             xmlns:converters="clr-namespace:EchoForge.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1200"
             xmlns:loc="clr-namespace:EchoForge.WPF.Localization"
             Background="#0B0E14" Foreground="#F8FAFC">

    <UserControl.Resources>
        <converters:DurationAndZoomMultiConverter x:Key="DurationAndZoomMultiConverter"/>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <!-- Audio player handled by NAudio in code-behind -->

        <!-- ═══════════════ HEADER BAR ═══════════════ -->
        <Border Grid.Row="0" Background="#12161F" BorderBrush="#1A1F2B" BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="True" Margin="20,0">
                <Button DockPanel.Dock="Left" Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_BackToDashboard]}" Style="{StaticResource SecondaryButton}" 
                        Command="{Binding GoBackCommand}" Padding="12,6" VerticalAlignment="Center" Margin="0,0,20,0"/>
                
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_VideoEditor]}" FontSize="16" FontWeight="Bold" Margin="0,0,12,0" Foreground="{StaticResource AccentPurpleBrush}"/>
                    <TextBlock Text="{Binding ProjectTitle, StringFormat='— {0}'}" FontSize="14" FontWeight="SemiBold" Foreground="#94A3B8" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Export/Render Button moved to header for better visibility -->
                <Button DockPanel.Dock="Right" Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_RenderFinalVideo]}" 
                        Command="{Binding RenderVideoCommand}"
                        Padding="16,8" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="14" FontWeight="Bold" Cursor="Hand">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Setter Property="Background">
                                <Setter.Value>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#10B981" Offset="0"/>
                                        <GradientStop Color="#059669" Offset="1"/>
                                    </LinearGradientBrush>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </DockPanel>
        </Border>

        <!-- ═══════════════ MAIN CONTENT ═══════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- ──── LEFT: PREVIEW AREA & PLAYBACK ──── -->
            <Grid Grid.Column="0" Margin="8,8,4,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#0D1117" CornerRadius="12" ClipToBounds="True">
                    <Grid>
                        <!-- Scene Preview Image (Always shows the image at playhead) -->
                        <Border Background="#161B22" CornerRadius="12">
                            <Grid>
                                <!-- No selection placeholder -->
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding PreviewImagePath, Converter={StaticResource StringToInverseVisibility}}">
                                    <TextBlock Text="🎬" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_VideoPreview]}" Foreground="#4A5568" FontSize="16" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- The Image & Effects Preview Overlays -->
                                <Grid Margin="16" Opacity="{Binding PreviewOpacity, FallbackValue=1.0}">
                                    
                                    <Image Source="{Binding PreviewImagePath}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality">
                                        <Image.Style>
                                            <Style TargetType="Image">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveScene.Filter}" Value="blur">
                                                        <Setter Property="Effect">
                                                            <Setter.Value>
                                                                <BlurEffect Radius="20" KernelType="Gaussian"/>
                                                            </Setter.Value>
                                                        </Setter>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding ActiveScene.Filter}" Value="grayscale">
                                                        <!-- WPF no native grayscale effect, simulate with simple opacity drop to trick the eye, or leave as null for now -->
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Image.Style>
                                    </Image>
                                    
                                    <!-- OVERLAYS FOR FILTERS -->
                                    <Rectangle Stretch="Fill" IsHitTestVisible="False">
                                        <Rectangle.Style>
                                            <Style TargetType="Rectangle">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <!-- Warm Filter (Orange tint) -->
                                                    <DataTrigger Binding="{Binding ActiveScene.Filter}" Value="warm">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Fill" Value="#22FF8C00"/>
                                                    </DataTrigger>
                                                    <!-- Cool Filter (Blue tint) -->
                                                    <DataTrigger Binding="{Binding ActiveScene.Filter}" Value="cool">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Fill" Value="#2200A2FF"/>
                                                    </DataTrigger>
                                                    <!-- Sepia Filter -->
                                                    <DataTrigger Binding="{Binding ActiveScene.Filter}" Value="sepia">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Fill" Value="#33704214"/>
                                                    </DataTrigger>
                                                    <!-- Vintage Filter -->
                                                    <DataTrigger Binding="{Binding ActiveScene.Filter}" Value="vintage">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Fill" Value="#44211105"/>
                                                    </DataTrigger>
                                                    <!-- High Contrast Filter (Simulated with black transparent) -->
                                                    <DataTrigger Binding="{Binding ActiveScene.Filter}" Value="highcontrast">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                        <Setter Property="Fill" Value="#11000000"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Rectangle.Style>
                                    </Rectangle>

                                    <!-- Vignette Overlay -->
                                    <Border IsHitTestVisible="False">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ActiveScene.Filter}" Value="vignette">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Border.Background>
                                            <RadialGradientBrush>
                                                <GradientStop Color="#00000000" Offset="0.6"/>
                                                <GradientStop Color="#BF000000" Offset="1.1"/>
                                            </RadialGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Grid>
                            </Grid>
                        </Border>

                        <!-- Active Scene info overlay -->
                        <Border Background="#E60B0E14" CornerRadius="0,0,10,0" HorizontalAlignment="Left" VerticalAlignment="Top" 
                                Padding="14,8"
                                Visibility="{Binding ActiveScene, Converter={StaticResource NullToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding ActiveScene.SceneNumber, StringFormat='Scene {0}'}" FontSize="14" FontWeight="Bold" Foreground="#A855F7"/>
                                <TextBlock Text=" • " FontSize="14" Foreground="#4A5568"/>
                                <TextBlock Text="{Binding ActiveScene.Transition, FallbackValue='none'}" FontSize="14" Foreground="#10B981" FontStyle="Italic"/>
                            </StackPanel>
                        </Border>

                        <!-- Total playback time overlay -->
                        <Border Background="#E60B0E14" CornerRadius="0,0,0,10" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                Padding="14,8">
                            <TextBlock Text="{Binding CurrentPlaybackTimeDisplay, FallbackValue='0:00 / 0:00'}" FontSize="14" FontWeight="Bold" Foreground="#F8FAFC"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- PLAYBACK CONTROLS -->
                <Border Grid.Row="1" Background="#12161F" CornerRadius="8" Margin="0,8,0,0" Padding="12,8">
                    <Grid>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <!-- Undo -->
                            <Button Content="↩️" Command="{Binding UndoCommand}" ToolTip="Undo" Style="{StaticResource SecondaryButton}" Width="40" Height="40" FontSize="18" Margin="0,0,16,0" Padding="0"/>
                            
                            <!-- Jump to Start -->
                            <Button Content="⏮" Command="{Binding SeekToStartCommand}" Style="{StaticResource SecondaryButton}" Width="40" Height="40" FontSize="16" Margin="0,0,8,0" Padding="0"/>
                            <!-- Play/Pause -->
                            <Button Command="{Binding TogglePlaybackCommand}" Width="50" Height="50" FontSize="20" Margin="0,0,8,0" Padding="0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                        <Setter Property="Content" Value="▶"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsPlaying}" Value="True">
                                                <Setter Property="Content" Value="⏸"/>
                                                <Setter Property="Background" Value="#F59E0B"/> <!-- Orange when playing -->
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <!-- Jump to End -->
                            <Button Content="⏭" Command="{Binding SeekToEndCommand}" Style="{StaticResource SecondaryButton}" Width="40" Height="40" FontSize="16" Margin="0,0,16,0" Padding="0"/>
                            
                            <!-- Redo -->
                            <Button Content="↪️" Command="{Binding RedoCommand}" ToolTip="Redo" Style="{StaticResource SecondaryButton}" Width="40" Height="40" FontSize="18" Padding="0"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- ──── RIGHT: PROPERTIES PANEL ──── -->
            <Border Grid.Column="1" Background="#12161F" Margin="4,8,8,8" CornerRadius="12">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20,16">
                        <!-- Properties Header with gradient accent -->
                        <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#1A8B5CF6" Offset="0"/>
                                    <GradientStop Color="#05FFFFFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_Properties]}" FontSize="18" FontWeight="Bold" Foreground="#F8FAFC"/>
                        </Border>

                        <!-- ═══════ PROJECT SETTINGS (shown when NO scene selected) ═══════ -->
                        <StackPanel Visibility="{Binding SelectedScene, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                            
                            <!-- Project Settings Header -->
                            <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1A1040" Offset="0"/>
                                        <GradientStop Color="#0D1B2A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_ProjectSettings]}" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_GlobalSettings]}" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </Border>

                            <!-- 🔊 Audio Volume Card -->
                            <Border Background="#0D1117" CornerRadius="10" Margin="0,0,0,12" BorderBrush="#1E293B" BorderThickness="1">
                                <Grid>
                                    <!-- Accent bar -->
                                    <Border Background="#3B82F6" Width="4" HorizontalAlignment="Left" CornerRadius="10,0,0,10"/>
                                    <StackPanel Margin="16,14">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="🔊" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_MusicVolume]}" FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider x:Name="VolumeSlider" Value="{Binding AudioVolume}" Minimum="0" Maximum="1" SmallChange="0.05" LargeChange="0.1" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding AudioVolume, StringFormat='{}{0:P0}'}" FontSize="12" FontWeight="Bold" Foreground="#3B82F6" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 🎬 Video Intro Fade Card -->
                            <Border Background="#0D1117" CornerRadius="10" Margin="0,0,0,12" BorderBrush="#1E293B" BorderThickness="1">
                                <Grid>
                                    <Border Background="#10B981" Width="4" HorizontalAlignment="Left" CornerRadius="10,0,0,10"/>
                                    <StackPanel Margin="16,14">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="🌅" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_VideoIntroFade]}" FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_IntroFadeDesc]}" FontSize="10" Foreground="#64748B" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Value="{Binding ProjectFadeIn}" Minimum="0" Maximum="5" SmallChange="0.1" TickFrequency="0.5" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ProjectFadeIn, StringFormat='{}{0:F1}s'}" FontSize="12" FontWeight="Bold" Foreground="#10B981" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- 🌙 Video Outro Fade Card -->
                            <Border Background="#0D1117" CornerRadius="10" Margin="0,0,0,12" BorderBrush="#1E293B" BorderThickness="1">
                                <Grid>
                                    <Border Background="#F59E0B" Width="4" HorizontalAlignment="Left" CornerRadius="10,0,0,10"/>
                                    <StackPanel Margin="16,14">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="🌙" FontSize="16" Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_VideoOutroFade]}" FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_OutroFadeDesc]}" FontSize="10" Foreground="#64748B" Margin="0,0,0,8"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="50"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Value="{Binding ProjectFadeOut}" Minimum="0" Maximum="5" SmallChange="0.1" TickFrequency="0.5" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding ProjectFadeOut, StringFormat='{}{0:F1}s'}" FontSize="12" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_SelectSceneHint]}" FontSize="11" Foreground="#475569" TextWrapping="Wrap" Margin="0,8,0,0"/>
                        </StackPanel>

                        <!-- ═══════ SCENE PROPERTIES (shown when a scene IS selected) ═══════ -->
                        <StackPanel Visibility="{Binding SelectedScene, Converter={StaticResource NullToVisibilityConverter}}">

                            <!-- Scene Number Header -->
                            <Border CornerRadius="10" Padding="14,10" Margin="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#2D1B69" Offset="0"/>
                                        <GradientStop Color="#1A1040" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="🎬" FontSize="16" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding SelectedScene.SceneNumber, StringFormat='Scene {0}'}" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC"/>
                                </StackPanel>
                            </Border>

                            <!-- Duration -->
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_Duration]}" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding SelectedScene.Duration, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ModernTextBox}" Margin="0,0,0,4"/>
                            <TextBlock Text="{Binding SelectedSceneDurationDisplay}" FontSize="11" Foreground="#4A5568" Margin="0,0,0,16"/>

                            <!-- Image Prompt -->
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_ImagePrompt]}" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding SelectedScene.Prompt, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ModernTextBox}" Height="90" 
                                     TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,12"/>

                            <!-- Regenerate Scene Image -->
                            <Button Style="{StaticResource SecondaryButton}" 
                                    Command="{Binding RegenerateSceneCommand}"
                                    Padding="10,12" Margin="0,0,0,20" HorizontalAlignment="Stretch"
                                    BorderBrush="#8B5CF6" BorderThickness="1" Background="#1A0D1117">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="✨" Margin="0,0,8,0"/>
                                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_RegenerateImage]}" FontWeight="SemiBold" Foreground="#A855F7"/>
                                </StackPanel>
                            </Button>

                            <!-- ═══ Transition Effect Gallery (Redesigned with color preview tiles) ═══ -->
                            <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,12">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1A1040" Offset="0"/>
                                        <GradientStop Color="#0F172A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_TransitionEffect]}" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_TransitionDesc]}" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </Border>
                            <ListBox SelectedValue="{Binding SelectedScene.Transition}" SelectedValuePath="Tag" 
                                     Background="Transparent" BorderThickness="0" Margin="0,0,0,16" 
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="4" />
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <Border x:Name="Bd" Background="#0D1117" BorderBrush="#1E293B" BorderThickness="1" CornerRadius="10" Margin="3" Padding="0" Cursor="Hand" Height="72">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#1A2234"/>
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#475569"/>
                                                        </Trigger>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Bd" Property="Background" Value="#2A1B54"/>
                                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#8B5CF6"/>
                                                            <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBoxItem Tag="none">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1E293B" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="🚫" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="None" FontSize="10" Foreground="#94A3B8" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="fade">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1A3B82F6" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="🌫️" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Fade" FontSize="10" Foreground="#3B82F6" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="smoothleft">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1A10B981" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="⬅️" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Left" FontSize="10" Foreground="#10B981" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="smoothright">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1A10B981" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="➡️" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Right" FontSize="10" Foreground="#10B981" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="zoompan">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1AF59E0B" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="🔍" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Zoom" FontSize="10" Foreground="#F59E0B" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="circlecrop">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1AEC4899" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="⭕" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Circle" FontSize="10" Foreground="#EC4899" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="dissolve">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1A8B5CF6" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="✨" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Dissolve" FontSize="10" Foreground="#8B5CF6" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="pixelize">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1A06B6D4" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="👾" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Pixel" FontSize="10" Foreground="#06B6D4" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="shake">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1AEF4444" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="🫨" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Shake" FontSize="10" Foreground="#EF4444" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="glitch">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1AEF4444" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="📺" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Glitch" FontSize="10" Foreground="#EF4444" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="flash">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1AF59E0B" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="⚡" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Flash" FontSize="10" Foreground="#F59E0B" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="pulse">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1AEC4899" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="💓" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Pulse" FontSize="10" Foreground="#EC4899" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="wipe">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1A10B981" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="🧹" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Wipe" FontSize="10" Foreground="#10B981" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="blinds">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1A06B6D4" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="🪟" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Blinds" FontSize="10" Foreground="#06B6D4" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                                <ListBoxItem Tag="spin">
                                    <StackPanel HorizontalAlignment="Center">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#1AF59E0B" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <TextBlock Text="🌀" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Spin" FontSize="10" Foreground="#F59E0B" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </ListBoxItem>
                            </ListBox>

                            <!-- Save Button -->
                            <Button Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_SaveAllChanges]}" 
                                    Style="{StaticResource PrimaryButton}" 
                                    Command="{Binding ApplySceneEditsCommand}"
                                    Padding="12,10" Margin="0,0,0,20" HorizontalAlignment="Stretch"/>

                            <!-- ═══ VISUAL EFFECTS ═══ -->
                            <Border CornerRadius="10" Padding="14,12" Margin="0,0,0,16">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#1A1040" Offset="0"/>
                                        <GradientStop Color="#0F172A" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel>
                                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_VisualEffects]}" FontSize="15" FontWeight="Bold" Foreground="#F8FAFC" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_VisualEffectsDesc]}" FontSize="11" Foreground="#64748B"/>
                                </StackPanel>
                            </Border>

                            <!-- Fade In Card -->
                            <Border Background="#0D1117" CornerRadius="10" Margin="0,0,0,10" BorderBrush="#1E293B" BorderThickness="1">
                                <Grid>
                                    <Border Background="#8B5CF6" Width="4" HorizontalAlignment="Left" CornerRadius="10,0,0,10"/>
                                    <StackPanel Margin="16,12">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="🌅" FontSize="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_FadeIn]}" FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Value="{Binding SelectedScene.FadeInDuration}" Minimum="0" Maximum="5" SmallChange="0.1" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedScene.FadeInDuration, StringFormat='{}{0:F1}s'}" FontSize="12" FontWeight="Bold" Foreground="#8B5CF6" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Fade Out Card -->
                            <Border Background="#0D1117" CornerRadius="10" Margin="0,0,0,10" BorderBrush="#1E293B" BorderThickness="1">
                                <Grid>
                                    <Border Background="#EC4899" Width="4" HorizontalAlignment="Left" CornerRadius="10,0,0,10"/>
                                    <StackPanel Margin="16,12">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="🌙" FontSize="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_FadeOut]}" FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Value="{Binding SelectedScene.FadeOutDuration}" Minimum="0" Maximum="5" SmallChange="0.1" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedScene.FadeOutDuration, StringFormat='{}{0:F1}s'}" FontSize="12" FontWeight="Bold" Foreground="#EC4899" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Speed Card -->
                            <Border Background="#0D1117" CornerRadius="10" Margin="0,0,0,10" BorderBrush="#1E293B" BorderThickness="1">
                                <Grid>
                                    <Border Background="#F59E0B" Width="4" HorizontalAlignment="Left" CornerRadius="10,0,0,10"/>
                                    <StackPanel Margin="16,12">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="⚡" FontSize="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_PlaybackSpeed]}" FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="45"/>
                                            </Grid.ColumnDefinitions>
                                            <Slider Value="{Binding SelectedScene.Speed}" Minimum="0.25" Maximum="4.0" SmallChange="0.25" IsSnapToTickEnabled="True" TickFrequency="0.25" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding SelectedScene.Speed, StringFormat='{}{0:F2}x'}" FontSize="12" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Color Filter Card -->
                            <Border Background="#0D1117" CornerRadius="10" Margin="0,0,0,10" BorderBrush="#1E293B" BorderThickness="1">
                                <Grid>
                                    <Border Background="#06B6D4" Width="4" HorizontalAlignment="Left" CornerRadius="10,0,0,10"/>
                                    <StackPanel Margin="16,12">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="🎨" FontSize="14" Margin="0,0,6,0"/>
                                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_ColorFilter]}" FontSize="13" FontWeight="SemiBold" Foreground="#E2E8F0" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ComboBox SelectedValue="{Binding SelectedScene.Filter}" SelectedValuePath="Content" Style="{StaticResource ModernComboBox}">
                                            <ComboBoxItem Content="none"/>
                                            <ComboBoxItem Content="grayscale"/>
                                            <ComboBoxItem Content="sepia"/>
                                            <ComboBoxItem Content="vintage"/>
                                            <ComboBoxItem Content="warm"/>
                                            <ComboBoxItem Content="cool"/>
                                            <ComboBoxItem Content="highcontrast"/>
                                            <ComboBoxItem Content="vignette"/>
                                            <ComboBoxItem Content="blur"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <!-- Loading Indicator -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,24,0,0"
                                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_Processing]}" FontSize="13" Foreground="#A855F7" FontStyle="Italic"/>
                        </StackPanel>
                        
                        <!-- Status message -->
                        <TextBlock Text="{Binding StatusMessage}" FontSize="13" Foreground="#10B981" TextWrapping="Wrap" HorizontalAlignment="Center" Margin="0,12,0,0"
                                   Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibility}}"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ═══════════════ TIMELINE TOOLBAR ═══════════════ -->
        <Border Grid.Row="2" Background="#12161F" Margin="16,0,16,0" Padding="8,6" CornerRadius="8,8,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <Button Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_Split]}" Command="{Binding SplitSceneCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,4,0" Padding="8,4" ToolTip="Split scene at the playhead"/>
                    <Button Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_Delete]}" Command="{Binding DeleteSceneCommand}" Style="{StaticResource SecondaryButton}" Foreground="#F43F5E" Padding="8,4" Margin="0,0,8,0" ToolTip="Delete selected scene"/>
                    <Border Width="1" Background="#2A2F3A" Margin="0,2,8,2"/>
                    <Button Content="[ In" Command="{Binding MarkInCommand}" Style="{StaticResource SecondaryButton}" Padding="8,4" Margin="0,0,4,0" ToolTip="Mark In point at current playhead position" Foreground="#3B82F6"/>
                    <Button Content="Out ]" Command="{Binding MarkOutCommand}" Style="{StaticResource SecondaryButton}" Padding="8,4" Margin="0,0,4,0" ToolTip="Mark Out point at current playhead position" Foreground="#3B82F6"/>
                    <Button Content="✂️ Trim" Command="{Binding TrimToRangeCommand}" Style="{StaticResource SecondaryButton}" Padding="8,4" Margin="0,0,4,0" ToolTip="Trim video to the selected In/Out range" Foreground="#F59E0B"
                            Visibility="{Binding HasRange, Converter={StaticResource BoolToVisibility}}"/>
                    <Button Content="✕" Command="{Binding ClearRangeCommand}" Style="{StaticResource SecondaryButton}" Padding="6,4" Margin="0,0,4,0" ToolTip="Clear range selection" FontSize="10"
                            Visibility="{Binding HasRange, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding RangeDisplay}" FontSize="10" Foreground="#3B82F6" VerticalAlignment="Center" Margin="4,0,0,0" FontStyle="Italic"/>
                </StackPanel>
                
                <!-- Zoom Slider (Right side) -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="0,0,4,0">
                    <!-- Timeline Tutorial Tip -->
                    <Border Background="#1A3B82F6" CornerRadius="6" Padding="8,4" Margin="0,0,12,0" Cursor="Help"
                            ToolTip="Timeline Tips:&#x0a;• Click a scene to select and edit it&#x0a;• Drag the right edge of a scene to resize&#x0a;• Use Split to cut a scene at the playhead&#x0a;• Set In/Out points then Trim to crop&#x0a;• Drag scenes to reorder them&#x0a;• Use the zoom slider to see more detail">
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_Tips]}" FontSize="10" Foreground="#3B82F6" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="🔍" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBlock Text="-" Foreground="#4A5568" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="14" FontWeight="Bold"/>
                    <Slider Value="{Binding ZoomScale}" Minimum="0.3" Maximum="3.0" Width="120" VerticalAlignment="Center"
                            TickFrequency="0.1" IsSnapToTickEnabled="False" SmallChange="0.1" LargeChange="0.5"
                            ToolTip="Timeline Zoom"/>
                    <TextBlock Text="+" Foreground="#4A5568" VerticalAlignment="Center" Margin="4,0,8,0" FontSize="14" FontWeight="Bold"/>
                    <TextBlock Text="{Binding ZoomScale, StringFormat='{}{0:F1}x'}" Foreground="#94A3B8" FontSize="11" VerticalAlignment="Center" Width="30"/>
                </StackPanel>

                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_DragHint]}" Foreground="#4A5568" FontSize="10" VerticalAlignment="Center" Margin="12,0,0,0"/>
            </DockPanel>
        </Border>

        <!-- ═══════════════ TIME RULER ═══════════════ -->
        <Border Grid.Row="3" Background="#0D1117" BorderBrush="#1A1F2B" BorderThickness="0,1,0,0" Height="28" Margin="0,0,0,0">
            <DockPanel Margin="16,0">
                <!-- Fixed label area -->
                <Border DockPanel.Dock="Left" Width="60">
                    <TextBlock Text="⏱ Time" FontSize="10" Foreground="#4A5568" VerticalAlignment="Center"/>
                </Border>
                <!-- Canvas for ticks AND playhead -->
                <Grid>
                    <Canvas x:Name="TimeRulerCanvas" Background="Transparent" ClipToBounds="True" 
                            MouseLeftButtonDown="TimeRulerCanvas_MouseLeftButtonDown"
                            MouseMove="TimeRulerCanvas_MouseMove"
                            MouseLeftButtonUp="TimeRulerCanvas_MouseLeftButtonUp"/>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ═══════════════ TIMELINE TRACK ═══════════════ -->
        <Border Grid.Row="4" Background="#12161F" BorderBrush="#1A1F2B" BorderThickness="0,1,0,0" MinHeight="140" MaxHeight="200">
            <DockPanel Margin="16,10">
                <!-- Fixed left label -->
                <StackPanel DockPanel.Dock="Left" Width="60" Margin="0,0,0,0">
                    <TextBlock Text="🎞️" FontSize="16" Margin="0,4,0,2"/>
                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_VideoTrack]}" FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ed_Track]}" FontSize="10" Foreground="#4A5568"/>
                </StackPanel>

                <!-- Scrollable Timeline Track with Playhead Overlay -->
                <Grid>
                    <ScrollViewer x:Name="TimelineScrollViewer" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                                  ScrollChanged="TimelineScrollViewer_ScrollChanged">
                        <Grid x:Name="TrackGrid" 
                              MouseLeftButtonDown="TrackGrid_MouseLeftButtonDown" 
                              MouseMove="TrackGrid_MouseMove"
                              MouseLeftButtonUp="TrackGrid_MouseLeftButtonUp"
                              Background="Transparent" MinWidth="{Binding ActualWidth, ElementName=TimelineScrollViewer}">
                            <!-- Track background lines -->
                            <Border Background="#08FFFFFF" CornerRadius="6" Height="110" VerticalAlignment="Top"/>

                            <!-- Scene blocks -->
                            <ItemsControl ItemsSource="{Binding Scenes}" Height="110" VerticalAlignment="Top"
                                          dd:DragDrop.IsDragSource="True"
                                          dd:DragDrop.IsDropTarget="True"
                                          dd:DragDrop.DropHandler="{Binding}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Scene Block -->
                                            <Border Grid.Column="0" MinWidth="12" MaxWidth="1000"
                                                    CornerRadius="6"
                                                    BorderBrush="#5A6FFF" BorderThickness="1.5"
                                                    Cursor="Hand" Margin="2,4,0,4">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                        <GradientStop Color="#2A1B4D" Offset="0"/>
                                                        <GradientStop Color="#1A1230" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <Border.Width>
                                                    <MultiBinding Converter="{StaticResource DurationAndZoomMultiConverter}">
                                                        <Binding Path="Duration"/>
                                                        <Binding Path="DataContext.ZoomScale" RelativeSource="{RelativeSource AncestorType=UserControl}"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                                <Border.InputBindings>
                                                    <MouseBinding MouseAction="LeftClick"
                                                                  Command="{Binding DataContext.SelectSceneCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                  CommandParameter="{Binding}"/>
                                                </Border.InputBindings>
                                                
                                                <!-- Selected outline trigger -->
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                <Setter Property="BorderBrush" Value="#A855F7"/>
                                                                <Setter Property="BorderThickness" Value="2"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>

                                                <Grid x:Name="SceneInnerGrid">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="60"/>
                                                        <RowDefinition Height="*"/>
                                                    </Grid.RowDefinitions>
                                                    <!-- Thumbnail -->
                                                    <Border Grid.Row="0" CornerRadius="5,5,0,0" ClipToBounds="True" Background="#1E232B">
                                                        <Image Source="{Binding ImagePath}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    </Border>
                                                    <!-- Info bar -->
                                                    <Border Grid.Row="1" Padding="8,4" Background="#0AFFFFFF" CornerRadius="0,0,5,5">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel Grid.Column="0">
                                                                <TextBlock Text="{Binding SceneNumber, StringFormat='Scene {0}'}" FontSize="11" FontWeight="Bold" Foreground="#F8FAFC"/>
                                                                <TextBlock Text="{Binding DurationStr, StringFormat='⏳ {0}'}" FontSize="9" Foreground="#94A3B8"/>
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="1" Text="{Binding Transition}" FontSize="9" Foreground="#10B981" 
                                                                       FontStyle="Italic" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                        </Grid>
                                                    </Border>
                                                    
                                                    <!-- Trim Handle (Right Edge) -->
                                                    <Border Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Right" Width="8" Background="Transparent"
                                                            Cursor="SizeWE" ToolTip="Drag to change duration"
                                                            MouseLeftButtonDown="SceneRightEdge_MouseLeftButtonDown"
                                                            MouseMove="SceneRightEdge_MouseMove"
                                                            MouseLeftButtonUp="SceneRightEdge_MouseLeftButtonUp"
                                                            Tag="{Binding}">
                                                        <!-- Visual Handle Indicator -->
                                                        <Border Width="4" HorizontalAlignment="Right" Background="#33FFFFFF" CornerRadius="2" Margin="0,15,2,15"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <!-- Transition indicator arrow between scenes -->
                                            <Border Grid.Column="1" Width="24" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0">
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="▶" FontSize="10" Foreground="#4A5568" HorizontalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Transition, FallbackValue=''}" FontSize="7" Foreground="#10B981" 
                                                               HorizontalAlignment="Center" FontStyle="Italic" TextTrimming="CharacterEllipsis" MaxWidth="24"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </ScrollViewer>

                    <!-- PLAYHEAD OVERLAY (Vertical Red Line) -->
                    <Canvas IsHitTestVisible="False">
                        <!-- Playhead group translated via ViewModel binding -->
                        <Canvas x:Name="PlayheadGroup">
                            <Canvas.RenderTransform>
                                <TranslateTransform X="{Binding PlayheadPixelPosition}" Y="0"/>
                            </Canvas.RenderTransform>
                            <!-- Vertical Red Line -->
                            <Line X1="0" Y1="-28" X2="0" Y2="140" Stroke="#EF4444" StrokeThickness="2"/>
                            <!-- Top Knob -->
                            <Polygon Points="-6,-28 6,-28 6,-18 0,-10 -6,-18" Fill="#EF4444"/>
                        </Canvas>
                    </Canvas>
                </Grid>
            </DockPanel>
        </Border>

        <!-- ═══════════════ AUDIO TRACK (Multi-track) ═══════════════ -->
        <Border Grid.Row="5" Background="#12161F" BorderBrush="#1A1F2B" BorderThickness="0,1,0,0" Height="50">
            <DockPanel Margin="16,4">
                <!-- Audio Label + Volume Slider -->
                <StackPanel DockPanel.Dock="Left" Width="200" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🔊" FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"
                               ToolTip="Ses Kontrolü / Volume Control"/>
                    <Slider Value="{Binding AudioVolume}" Minimum="0" Maximum="1" Width="100" 
                            VerticalAlignment="Center" TickFrequency="0.05" IsSnapToTickEnabled="False"
                            SmallChange="0.05" LargeChange="0.1"
                            ToolTip="Ses Seviyesi / Volume"/>
                    <TextBlock Text="{Binding AudioVolume, StringFormat='{}{0:P0}'}" FontSize="10" 
                               Foreground="#10B981" VerticalAlignment="Center" Margin="6,0,0,0" Width="35"/>
                </StackPanel>
                
                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled" 
                              x:Name="AudioScrollViewer" IsHitTestVisible="False">
                    <Grid x:Name="AudioTrackGrid" Background="Transparent" MinWidth="{Binding ActualWidth, ElementName=AudioScrollViewer}">
                        <!-- Audio track background -->
                        <Border Background="#08FFFFFF" CornerRadius="6" Height="36" VerticalAlignment="Center" HorizontalAlignment="Left" x:Name="AudioTrackBackground"/>
                        
                        <!-- The Audio Clip Block -->
                        <Border x:Name="AudioClipBlock" Background="#1A10B981" CornerRadius="4" Height="30" VerticalAlignment="Center" HorizontalAlignment="Left"
                                BorderBrush="#4D10B981" BorderThickness="1" Cursor="Hand" ToolTip="Background Music">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#3310B981"/>
                                            <Setter Property="BorderBrush" Value="#8010B981"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <!-- Simulated Waveform Background -->
                                <Path Fill="#3310B981" Stretch="Fill" Data="M 0,15 L 5,5 L 10,12 L 15,3 L 20,18 L 25,6 L 30,14 L 35,5 L 40,11 L 45,2 L 50,16 L 55,7 L 60,13 L 65,4 L 70,17 L 75,8 L 80,15 L 85,6 L 90,12 L 95,3 L 100,15 Z" Opacity="0.5" VerticalAlignment="Bottom" Height="20"/>
                                
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="12,0,0,0">
                                    <TextBlock Text="🎵 BGM Track" FontSize="10" Foreground="#10B981" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding TotalDurationDisplay}" FontSize="9" Foreground="#6EE7B7" Margin="8,0,0,0" VerticalAlignment="Center" FontStyle="Italic"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
