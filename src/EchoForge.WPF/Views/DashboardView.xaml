<UserControl x:Class="EchoForge.WPF.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:EchoForge.WPF.Converters"
             xmlns:loc="clr-namespace:EchoForge.WPF.Localization">

    <UserControl.Resources>
        <converters:StatusToProgressConverter x:Key="StatusToProgress"/>
        <converters:StatusVisibilityConverter x:Key="StatusVisibility"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="0,0,0,40">
            
            <!-- ═══════════════ HEADER ═══════════════ -->
            <DockPanel Margin="0,0,0,32">
                <StackPanel>
                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Dash_Greeting]}" FontSize="36" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Dash_Subtitle]}" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                </StackPanel>
                <Button Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Dash_Refresh]}" Command="{Binding RefreshProjectsCommand}"
                        Style="{StaticResource SecondaryButton}" HorizontalAlignment="Right"
                        VerticalAlignment="Center" Padding="16,10" Foreground="{StaticResource TextSecondaryBrush}"/>
            </DockPanel>

            <!-- ═══════════════ HERO ACTIONS ═══════════════ -->
            <Grid Margin="0,0,0,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="1*"/>
                </Grid.ColumnDefinitions>

                <!-- Create New Project (Hero) -->
                <Border Grid.Column="0" CornerRadius="16" Margin="0,0,24,0" Cursor="Hand" Padding="32" 
                        Background="#2A10B981" BorderBrush="#5510B981" BorderThickness="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3310B981"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <!-- Route this to NavigateToCreateCommand via MainWindow context -->
                    <DockPanel>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Dash_CreateHeroTitle]}" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,12"/>
                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Dash_CreateHeroDesc]}" 
                                       FontSize="14" Foreground="#D1FAE5" TextWrapping="Wrap" MaxWidth="400" HorizontalAlignment="Left" LineHeight="20"/>
                            
                            <Button Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Dash_LaunchCreator]}" Style="{StaticResource PrimaryButton}" Margin="0,24,0,0" HorizontalAlignment="Left" Padding="32,14" FontSize="16" FontWeight="Bold" Background="#059669" BorderThickness="0"
                                    Command="{Binding DataContext.NavigateToCreateCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                        </StackPanel>
                        <!-- Decorative Hero Icon -->
                        <TextBlock Text="🎬" FontSize="80" HorizontalAlignment="Right" VerticalAlignment="Center" Opacity="0.5" Margin="0,0,32,0"/>
                    </DockPanel>
                </Border>

                <!-- Quick Stats 1: Projects Overview -->
                <Border Grid.Column="1" Style="{StaticResource GlassCard}" Margin="0,0,24,0" Padding="24">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Dash_TotalProjects]}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalProjects}" FontSize="42" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center"/>
                        <Border Background="#1A10B981" CornerRadius="8" Padding="12,6" Margin="0,16,0,0">
                            <TextBlock Text="{Binding TotalCompleted, StringFormat='{}✅ {0} Completed'}" FontSize="13" Foreground="{StaticResource AccentGreenBrush}" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="{Binding SuccessRate, StringFormat='{}Target Success: {0}'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Quick Stats 2: Active Renders -->
                <Border Grid.Column="2" Style="{StaticResource GlassCard}" Padding="24">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Dash_ActiveRender]}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding TotalProcessing}" FontSize="42" FontWeight="Bold" Foreground="{StaticResource AccentOrangeBrush}" HorizontalAlignment="Center"/>
                        <Border Background="#1A3B82F6" CornerRadius="8" Padding="12,6" Margin="0,16,0,0">
                            <TextBlock Text="{Binding RecentProjectsCount, StringFormat='{}📈 {0} Last 7 Days'}" FontSize="13" Foreground="{StaticResource AccentBlueBrush}" FontWeight="SemiBold"/>
                        </Border>
                        <TextBlock Text="{Binding TotalStorageUsed, StringFormat='{}💾 {0} media data'}" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══════════════ RECENT PROJECTS VIEW ═══════════════ -->
            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Dash_RecentCreations]}" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,24"/>
            
            <ItemsControl ItemsSource="{Binding Projects}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Project Card (Glass) -->
                        <Border Width="300" Height="260" Margin="0,0,24,24" Padding="0" Cursor="Hand" ClipToBounds="True">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" 
                                              Command="{Binding DataContext.OpenEditorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                              CommandParameter="{Binding}" />
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource GlassCard}">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}"/>
                                            <Setter Property="Background" Value="#25FFFFFF"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="120"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Top Media Area -->
                                <Border Grid.Row="0" Margin="0">
                                    <!-- Dynamic Gradient Background Based on theme -->
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#2A0B0F19" Offset="0"/>
                                            <GradientStop Color="#400D0914" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    
                                    <Grid>
                                        <!-- Status indicator top-right -->
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top" Margin="12" Padding="12,6" CornerRadius="8" Background="#800B0F19" BorderBrush="#33FFFFFF" BorderThickness="1">
                                            <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                        <!-- Big Icon -->
                                        <TextBlock Text="📽️" FontSize="48" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.6"/>
                                    </Grid>
                                </Border>

                                <!-- Mid Details -->
                                <StackPanel Grid.Row="1" Margin="20">
                                    <TextBlock Text="{Binding Title}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,8,0,0">
                                        <TextBlock.Text>
                                            <MultiBinding StringFormat="{}{0} • {1:F0} BPM">
                                                <Binding Path="TemplateName"/>
                                                <Binding Path="BPM"/>
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>

                                <!-- Footer Actions -->
                                <DockPanel Grid.Row="2" Margin="20,0,20,20">
                                    <Button DockPanel.Dock="Left" Content="✂️ Edit Video" Style="{StaticResource PrimaryButton}" Padding="16,8" FontSize="13" Background="#15FFFFFF" Foreground="White" BorderThickness="0"
                                            Command="{Binding DataContext.OpenEditorCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            Visibility="{Binding Status, Converter={StaticResource StatusVisibility}, ConverterParameter='ReviewingScenes,AwaitingApproval,Completed'}"/>
                                    
                                    <Button DockPanel.Dock="Right" Content="🗑️" Style="{StaticResource SecondaryButton}" Foreground="{StaticResource AccentRedBrush}" Padding="12,8" HorizontalAlignment="Right"
                                            Command="{Binding DataContext.DeleteProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"/>
                                </DockPanel>

                                <!-- In Progress Overlay (Locks Card) -->
                                <Border Grid.RowSpan="3" Background="#F20D1117"
                                        Visibility="{Binding Status, Converter={StaticResource StatusVisibility}, ConverterParameter='Created,AnalyzingAudio,GeneratingImages,ComposingVideo,GeneratingSEO,Uploading'}">
                                    <Grid>
                                        <!-- Header Actions (Delete inside Overlay) -->
                                        <Button Content="✕ Cancel / Delete" Style="{StaticResource SecondaryButton}" 
                                                Foreground="{StaticResource AccentRedBrush}" Background="#20FF3333" BorderBrush="{StaticResource AccentRedBrush}"
                                                HorizontalAlignment="Right" VerticalAlignment="Top" Margin="16" Padding="12,6" FontSize="12"
                                                Command="{Binding DataContext.DeleteProjectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                CommandParameter="{Binding}"/>
                                                
                                        <!-- Centered Progress Info -->
                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Dash_RenderActive]}" FontSize="15" FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToProgress}}" 
                                                       FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" FontWeight="SemiBold"
                                                       TextAlignment="Center" LineHeight="20"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
