<UserControl x:Class="EchoForge.WPF.Views.YouTubeVideosView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:EchoForge.WPF.Localization"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1200"
             Background="#0B0E14" Foreground="#F8FAFC">

    <DockPanel>
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Vid_Title]}" Style="{StaticResource HeaderLabel}"/>
            <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource SubHeaderLabel}" Margin="0,4,0,0"/>
        </StackPanel>

        <!-- Channel Selector + Search Bar -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
            <!-- Channel Selector -->
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Vid_Channel]}" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding Channels}" SelectedItem="{Binding SelectedChannel}" 
                          DisplayMemberPath="ChannelName" Style="{StaticResource ModernComboBox}" 
                          Width="220" Margin="0,0,16,0"/>
                <Button Command="{Binding LoadChannelsCommand}" Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Vid_Refresh]}" 
                        Style="{StaticResource SecondaryButton}" Padding="12,8" Margin="0,0,16,0"/>
            </StackPanel>

            <!-- Search -->
            <DockPanel DockPanel.Dock="Right" HorizontalAlignment="Right" Margin="0,0,0,0">
                <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}" 
                         Style="{StaticResource ModernTextBox}" Width="200"
                         ToolTip="Search videos by title"/>
            </DockPanel>
        </DockPanel>

        <!-- Stats Bar -->
        <Border DockPanel.Dock="Top" Background="#12161F" CornerRadius="8" Padding="16,10" Margin="0,0,0,16">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📊 Total Videos:" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding TotalVideoCount}" Foreground="#A855F7" FontSize="15" FontWeight="Bold" Margin="8,0,20,0" VerticalAlignment="Center"/>
                <TextBlock Text="📺 Active Channel:" Foreground="#94A3B8" FontSize="13" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding SelectedChannel.ChannelName, FallbackValue='None selected'}" Foreground="#10B981" FontSize="13" FontWeight="SemiBold" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Loading -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,8"
                    Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
            <TextBlock Text="⏳ Loading videos..." FontSize="14" Foreground="#A855F7" FontStyle="Italic"/>
        </StackPanel>

        <!-- Video Grid -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Videos}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#12161F" CornerRadius="10" Margin="0,0,12,12" Width="280" 
                                BorderBrush="#1E293B" BorderThickness="1" Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding DataContext.OpenVideoInBrowserCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              CommandParameter="{Binding VideoId}"/>
                            </Border.InputBindings>
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="158"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Thumbnail -->
                                <Border Grid.Row="0" CornerRadius="10,10,0,0" ClipToBounds="True" Background="#1E232B">
                                    <Image Source="{Binding ThumbnailUrl}" Stretch="UniformToFill" 
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                </Border>

                                <!-- Privacy Badge -->
                                <Border Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                        Margin="0,8,8,0" Padding="6,3" CornerRadius="4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#33000000"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding PrivacyStatus}" Value="public">
                                                    <Setter Property="Background" Value="#3310B981"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PrivacyStatus}" Value="private">
                                                    <Setter Property="Background" Value="#33F43F5E"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding PrivacyStatus}" Value="unlisted">
                                                    <Setter Property="Background" Value="#33F59E0B"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding PrivacyStatus}" FontSize="10" Foreground="#F8FAFC" FontWeight="SemiBold"/>
                                </Border>

                                <!-- Info -->
                                <StackPanel Grid.Row="1" Margin="12,10,12,12">
                                    <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="SemiBold" Foreground="#F8FAFC" 
                                               TextTrimming="CharacterEllipsis" MaxHeight="36" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="👁 " FontSize="11" Foreground="#94A3B8"/>
                                        <TextBlock Text="{Binding ViewCount, StringFormat='{}{0:N0}'}" FontSize="11" Foreground="#94A3B8" Margin="0,0,12,0"/>
                                        <TextBlock Text="❤ " FontSize="11" Foreground="#EC4899"/>
                                        <TextBlock Text="{Binding LikeCount, StringFormat='{}{0:N0}'}" FontSize="11" Foreground="#94A3B8" Margin="0,0,12,0"/>
                                        <TextBlock Text="💬 " FontSize="11" Foreground="#3B82F6"/>
                                        <TextBlock Text="{Binding CommentCount, StringFormat='{}{0:N0}'}" FontSize="11" Foreground="#94A3B8"/>
                                    </StackPanel>
                                    <TextBlock Text="{Binding PublishedAt, StringFormat='Published: {0:yyyy-MM-dd}'}" 
                                               FontSize="10" Foreground="#4A5568" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
