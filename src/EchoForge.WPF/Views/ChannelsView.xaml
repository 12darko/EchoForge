<UserControl x:Class="EchoForge.WPF.Views.ChannelsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:loc="clr-namespace:EchoForge.WPF.Localization"
             xmlns:converters="clr-namespace:EchoForge.WPF.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000"
             Foreground="White">

    <UserControl.Resources>
        <converters:BoolToVisibilityConverter x:Key="AdminVisibilityConverter"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,28">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_Title]}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_Subtitle]}" FontSize="14" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>

            <!-- Tutorial Button -->
            <Button Grid.Column="1" Command="{Binding ShowTutorialCommand}" 
                    Padding="16,10" Height="42" Margin="0,0,12,0"
                    Style="{StaticResource SecondaryButton}" VerticalAlignment="Center"
                    ToolTip="Learn how to get your YouTube API credentials">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📖" FontSize="16" Margin="0,0,6,0"/>
                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_HowToConnect]}" FontWeight="SemiBold" FontSize="13"/>
                </StackPanel>
            </Button>

            <!-- Connect Channel -->
            <Border Grid.Column="2" Style="{StaticResource GlassCard}" Padding="16,12" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Command="{Binding ConnectChannelCommand}" 
                            Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_Connect]}" 
                            Style="{StaticResource PrimaryButton}" 
                            Padding="20,8" Height="38"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Main Content Split: Left (Channels + OAuth Config), Right (Videos) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="24"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Channels List + OAuth Settings -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Connected Channels Card -->
                    <Border Style="{StaticResource GlassCard}" Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_ConnectedChannels]}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Border Background="#8B5CF6" CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Channels.Count}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>

                            <ListView Grid.Row="1" ItemsSource="{Binding Channels}" SelectedItem="{Binding SelectedChannel}"
                                      Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="280">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Border CornerRadius="12" Margin="0,0,0,8" Padding="16">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#0CFFFFFF" Offset="0"/>
                                                    <GradientStop Color="#06FFFFFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="44"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Channel Avatar -->
                                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#8B5CF6" Margin="0,0,12,0">
                                                    <TextBlock Text="📺" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ChannelName}" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" Margin="0,0,0,2"/>
                                                    <TextBlock Text="{Binding ChannelId}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                                </StackPanel>

                                                <Button Grid.Column="2" Command="{Binding DataContext.DeleteChannelCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                                                        CommandParameter="{Binding Id}"
                                                        Content="🗑️" 
                                                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource AccentRedBrush}"
                                                        ToolTip="Delete" Cursor="Hand" FontSize="14"
                                                        VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                                <ListView.ItemContainerStyle>
                                    <Style TargetType="ListViewItem">
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Margin" Value="0"/>
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListViewItem">
                                                    <Border CornerRadius="12" Name="Border">
                                                        <ContentPresenter/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <Trigger Property="IsSelected" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#208B5CF6"/>
                                                        </Trigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="Border" Property="Background" Value="#10FFFFFF"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListView.ItemContainerStyle>
                            </ListView>

                            <!-- Empty state -->
                            <Border Grid.Row="1" Visibility="{Binding HasNoChannels, Converter={StaticResource BooleanToVisibilityConverter}}" VerticalAlignment="Center" HorizontalAlignment="Center">
                                <StackPanel HorizontalAlignment="Center">
                                    <TextBlock Text="📡" FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_NoChannels]}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="14" HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_EnterChannelId]}" Foreground="#484F58" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Loading overlay (only inside channel list) -->
                            <Border Grid.Row="1" Background="#800D1117" Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    CornerRadius="8" Panel.ZIndex="10" IsHitTestVisible="False">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="⏳ Yükleniyor..." Foreground="#8B5CF6" FontSize="14" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ═══════ YouTube OAuth Credentials Card (Admin Only) ═══════ -->
                    <Border Style="{StaticResource GlassCard}" Padding="20" Margin="0,0,0,16"
                            Visibility="{Binding IsAdmin, Converter={StaticResource AdminVisibilityConverter}}">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_ApiCredentials]}" FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <Button Command="{Binding ShowTutorialCommand}" Content="❓" 
                                        Background="Transparent" BorderThickness="0" Foreground="{StaticResource AccentBlueBrush}"
                                        FontSize="14" Margin="8,0,0,0" Cursor="Hand" ToolTip="How to get API credentials"/>
                            </StackPanel>

                            <Border Background="#1A0D1117" BorderBrush="#1AFFFFFF" BorderThickness="1" CornerRadius="10" Padding="12" Margin="0,0,0,16">
                                <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_ApiHelp]}" 
                                           Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" TextWrapping="Wrap"/>
                            </Border>

                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_ClientId]}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding YouTubeClientId, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                            <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_ClientSecret]}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                            <TextBox Text="{Binding YouTubeClientSecret, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBox}" Margin="0,0,0,16"/>

                            <Button Content="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_SaveCredentials]}" Command="{Binding SaveCredentialsCommand}" 
                                    Style="{StaticResource PrimaryButton}" Height="40" FontSize="13"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- RIGHT PANEL: Channel Videos -->
            <Border Grid.Column="2" Style="{StaticResource GlassCard}" Padding="24">
                <Grid>
                    <!-- If no channel selected -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="{Binding SelectedChannel, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter=Inverse}">
                        <TextBlock Text="🎬" FontSize="64" HorizontalAlignment="Center" Foreground="{StaticResource AccentPurpleBrush}" Opacity="0.5" Margin="0,0,0,16"/>
                        <TextBlock Text="{Binding Source={x:Static loc:TranslationManager.Instance}, Path=Strings[Ch_SelectChannel]}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="15" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Videos Grid -->
                    <Grid Visibility="{Binding SelectedChannel, Converter={StaticResource NullToVisibilityConverter}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                            <TextBlock Text="{Binding SelectedChannel.ChannelName, StringFormat='Videos of {0}'}" 
                                       FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                            <Border Background="#10B981" CornerRadius="10" Padding="8,2" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding SelectedChannelVideos.Count, StringFormat='{}{0} videos'}" FontSize="11" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding SelectedChannelVideos}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Margin="-8"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Width="280" CornerRadius="14" Margin="8" Padding="0" BorderBrush="#15FFFFFF" BorderThickness="1">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#0CFFFFFF" Offset="0"/>
                                                    <GradientStop Color="#04FFFFFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <StackPanel>
                                                <!-- Thumbnail -->
                                                <Border CornerRadius="14,14,0,0" ClipToBounds="True">
                                                    <Image Source="{Binding ThumbnailUrl}" Height="157" Stretch="UniformToFill"/>
                                                </Border>

                                                <!-- Details -->
                                                <Border Padding="16">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}" 
                                                                   TextWrapping="Wrap" MaxHeight="40" TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                                                        
                                                        <TextBlock Text="{Binding Description}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" 
                                                                   TextWrapping="Wrap" MaxHeight="32" TextTrimming="CharacterEllipsis" Margin="0,0,0,12"/>

                                                        <!-- Stats -->
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                                <TextBlock Text="👁️ " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                                                <TextBlock Text="{Binding ViewCount}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                                <TextBlock Text="👍 " Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                                                <TextBlock Text="{Binding LikeCount}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" FontWeight="SemiBold"/>
                                                            </StackPanel>
                                                            
                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                                                <Border Background="{StaticResource AccentGreenBrush}" CornerRadius="6" Padding="8,4" Visibility="{Binding PrivacyStatus, Converter={StaticResource StringMatchToVisibilityConverter}, ConverterParameter=public}">
                                                                    <TextBlock Text="PUBLIC" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                                                </Border>
                                                                <Border Background="#1AFFFFFF" CornerRadius="6" Padding="8,4" Visibility="{Binding PrivacyStatus, Converter={StaticResource StringMatchToVisibilityConverter}, ConverterParameter=private}">
                                                                    <TextBlock Text="PRIVATE" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontWeight="Bold"/>
                                                                </Border>
                                                            </StackPanel>
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- ═══════ Tutorial Popup Overlay ═══════ -->
        <Grid Grid.Row="0" Grid.RowSpan="2" Panel.ZIndex="100" 
              Visibility="{Binding IsTutorialVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
            
            <!-- Dark backdrop -->
            <Border Background="#CC000000">
                <Border.InputBindings>
                    <MouseBinding Gesture="LeftClick" Command="{Binding CloseTutorialCommand}"/>
                </Border.InputBindings>
            </Border>

            <!-- Tutorial Card -->
            <Border MaxWidth="620" MaxHeight="600" HorizontalAlignment="Center" VerticalAlignment="Center"
                    CornerRadius="20" Padding="0" BorderBrush="#30FFFFFF" BorderThickness="1">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#FF1A1B2E" Offset="0"/>
                        <GradientStop Color="#FF0D1117" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <!-- Header -->
                    <Border Grid.Row="0" Padding="28,24,28,20" BorderBrush="#10FFFFFF" BorderThickness="0,0,0,1">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="📖 How to Connect Your YouTube Channel" FontSize="20" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Follow these steps to get your YouTube API credentials" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
                            </StackPanel>
                            <Button Content="✕" HorizontalAlignment="Right" VerticalAlignment="Top" 
                                    Command="{Binding CloseTutorialCommand}"
                                    Background="Transparent" BorderThickness="0" Foreground="{StaticResource TextSecondaryBrush}" 
                                    FontSize="18" Cursor="Hand"/>
                        </Grid>
                    </Border>

                    <!-- Steps -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="28,20">
                        <StackPanel>

                            <!-- Step 1 -->
                            <Border CornerRadius="12" Margin="0,0,0,16" Padding="16" Background="#08FFFFFF">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#8B5CF6" Margin="0,0,10,0">
                                            <TextBlock Text="1" FontWeight="Bold" FontSize="13" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Go to Google Cloud Console" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="38,0,0,0">
                                        Visit <Hyperlink NavigateUri="https://console.cloud.google.com" Foreground="#8B5CF6">console.cloud.google.com</Hyperlink> and sign in with your Google account. Create a new project (e.g., "EchoForge Studio").
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Step 2 -->
                            <Border CornerRadius="12" Margin="0,0,0,16" Padding="16" Background="#08FFFFFF">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#8B5CF6" Margin="0,0,10,0">
                                            <TextBlock Text="2" FontWeight="Bold" FontSize="13" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Enable YouTube Data API v3" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="38,0,0,0">
                                        Go to "APIs &amp; Services" → "Library". Search for "YouTube Data API v3" and click "Enable".
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Step 3 -->
                            <Border CornerRadius="12" Margin="0,0,0,16" Padding="16" Background="#08FFFFFF">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#8B5CF6" Margin="0,0,10,0">
                                            <TextBlock Text="3" FontWeight="Bold" FontSize="13" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Create OAuth Consent Screen" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="38,0,0,0">
                                        Go to "OAuth consent screen". Choose "External" type. Fill in the app name ("EchoForge") and your email. Add scopes: "youtube.upload" and "youtube.readonly". Add your email as a test user.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Step 4 -->
                            <Border CornerRadius="12" Margin="0,0,0,16" Padding="16" Background="#08FFFFFF">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#8B5CF6" Margin="0,0,10,0">
                                            <TextBlock Text="4" FontWeight="Bold" FontSize="13" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Create OAuth 2.0 Credentials" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="38,0,0,0">
                                        Go to "Credentials" → "Create Credentials" → "OAuth Client ID". Choose "Web application" as the type. Add "http://localhost" to Authorized redirect URIs. Copy the Client ID and Client Secret.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Step 5 -->
                            <Border CornerRadius="12" Margin="0,0,0,0" Padding="16" Background="#0A10B981" BorderBrush="#2010B981" BorderThickness="1">
                                <StackPanel>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                        <Border Width="28" Height="28" CornerRadius="14" Background="#10B981" Margin="0,0,10,0">
                                            <TextBlock Text="5" FontWeight="Bold" FontSize="13" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="Paste Credentials Here &amp; Connect!" FontSize="15" FontWeight="SemiBold" Foreground="#10B981" VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock TextWrapping="Wrap" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="38,0,0,0">
                                        Paste the Client ID and Client Secret into the fields on the left panel. Click "Save Credentials", then enter your Channel ID and click "🔗 Connect". A browser window will open for YouTube authorization.
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </ScrollViewer>

                    <!-- Footer -->
                    <Border Grid.Row="2" Padding="28,16" BorderBrush="#10FFFFFF" BorderThickness="0,1,0,0">
                        <Button Content="Got it! Close Tutorial" Command="{Binding CloseTutorialCommand}" 
                                Style="{StaticResource PrimaryButton}" Height="42" FontSize="14" HorizontalAlignment="Stretch"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
