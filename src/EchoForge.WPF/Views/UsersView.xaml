<UserControl x:Class="EchoForge.WPF.Views.UsersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:loc="clr-namespace:EchoForge.WPF.Localization">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ HEADER ═══ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="👥 Kullanıcı Yönetimi" FontSize="28" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Sadece yöneticiler bu sayfayı görebilir. Hesap ekleyin, düzenleyin veya devre dışı bırakın."
                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0"/>
        </StackPanel>

        <!-- ═══ MAIN CONTENT ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ──── LEFT: CREATE USER CARD ──── -->
            <Border Grid.Column="0" Background="{StaticResource CardDarkBrush}"
                    CornerRadius="12" Padding="24" Margin="0,0,16,0"
                    BorderBrush="#15FFFFFF" BorderThickness="1"
                    VerticalAlignment="Top"
                    Effect="{StaticResource ShadowEffect}">
                <StackPanel>
                    <!-- Card Header -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                        <TextBlock Text="➕" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Yeni Kullanıcı Ekle" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Username -->
                    <TextBlock Text="KULLANICI ADI" FontSize="10" FontWeight="Bold"
                               Foreground="#8B949E" Margin="0,0,0,6"/>
                    <TextBox Text="{Binding NewUsername, UpdateSourceTrigger=PropertyChanged}"
                             Padding="12,10" FontSize="14" Margin="0,0,0,16"
                             Background="#161B22" Foreground="White"
                             BorderBrush="#30363D" BorderThickness="1"
                             CaretBrush="White">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="TextBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <!-- Password -->
                    <TextBlock Text="ŞİFRE" FontSize="10" FontWeight="Bold"
                               Foreground="#8B949E" Margin="0,0,0,6"/>
                    <PasswordBox x:Name="PasswordInput"
                                 Padding="12,10" FontSize="14" Margin="0,0,0,24"
                                 Background="#161B22" Foreground="White"
                                 BorderBrush="#30363D" BorderThickness="1"
                                 PasswordChanged="PasswordInput_PasswordChanged">
                        <PasswordBox.Style>
                            <Style TargetType="PasswordBox">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="PasswordBox">
                                            <Border Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    CornerRadius="8">
                                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsFocused" Value="True">
                                                    <Setter Property="BorderBrush" Value="#8B5CF6"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </PasswordBox.Style>
                    </PasswordBox>

                    <!-- Create Button -->
                    <Button Command="{Binding CreateUserCommand}" Style="{StaticResource PrimaryButton}" 
                            Padding="16,12" FontSize="14" FontWeight="SemiBold"
                            HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="✨" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock Text="Kullanıcı Oluştur"/>
                        </StackPanel>
                    </Button>

                    <!-- Status Message -->
                    <TextBlock Text="{Binding StatusMessage}" FontSize="12"
                               Foreground="#F0883E" TextWrapping="Wrap"
                               Margin="0,16,0,0"
                               Visibility="{Binding StatusMessage.Length, Converter={StaticResource BoolToVis}, FallbackValue=Collapsed}"/>
                </StackPanel>
            </Border>

            <!-- ──── RIGHT: USERS LIST ──── -->
            <Border Grid.Column="1" Background="{StaticResource CardDarkBrush}"
                    CornerRadius="12" Padding="24"
                    BorderBrush="#15FFFFFF" BorderThickness="1"
                    Effect="{StaticResource ShadowEffect}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- List Header -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
                        <TextBlock Text="📋" FontSize="20" Margin="0,0,10,0"/>
                        <TextBlock Text="Mevcut Kullanıcılar" FontSize="18" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <Border Background="#30363D" CornerRadius="10" Padding="10,4" Margin="12,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding Users.Count, StringFormat='{}{0} kullanıcı'}"
                                       FontSize="11" Foreground="#8B949E"/>
                        </Border>
                    </StackPanel>

                    <!-- Column Headers -->
                    <Border Grid.Row="1" Background="#0D1117" CornerRadius="8" Padding="16,10" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="" FontSize="10" FontWeight="Bold" Foreground="#484F58"/>
                            <TextBlock Grid.Column="1" Text="KULLANICI" FontSize="10" FontWeight="Bold" Foreground="#484F58"/>
                            <TextBlock Grid.Column="2" Text="OLUŞTURULMA" FontSize="10" FontWeight="Bold" Foreground="#484F58"/>
                            <TextBlock Grid.Column="3" Text="SON GİRİŞ" FontSize="10" FontWeight="Bold" Foreground="#484F58"/>
                            <TextBlock Grid.Column="4" Text="İŞLEMLER" FontSize="10" FontWeight="Bold" Foreground="#484F58" HorizontalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Users List -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding Users}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#0D1117" CornerRadius="8" Margin="0,0,0,4" Padding="16,12">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#161B22"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="40"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="120"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Status Dot -->
                                            <Ellipse Grid.Column="0" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Ellipse.Style>
                                                    <Style TargetType="Ellipse">
                                                        <Setter Property="Fill" Value="#F85149"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Fill" Value="#3FB950"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Ellipse.Style>
                                            </Ellipse>

                                            <!-- Username + Email -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Username}" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                                                <TextBlock Text="{Binding Email}" FontSize="11" Foreground="#8B949E" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <!-- Created At -->
                                            <TextBlock Grid.Column="2" Text="{Binding CreatedAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"
                                                       FontSize="12" Foreground="#8B949E" VerticalAlignment="Center"/>

                                            <!-- Last Login -->
                                            <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                                       FontSize="12" Foreground="#8B949E">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding LastLoginAt, StringFormat='{}{0:dd.MM.yyyy HH:mm}'}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LastLoginAt}" Value="{x:Null}">
                                                                <Setter Property="Text" Value="—"/>
                                                                <Setter Property="Foreground" Value="#484F58"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- Actions -->
                                            <StackPanel Grid.Column="4" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <!-- Toggle Active -->
                                                <Button Command="{Binding DataContext.ToggleUserActiveCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Aktif/Pasif Yap" Cursor="Hand"
                                                        Width="32" Height="32" Margin="0,0,4,0">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="Transparent" CornerRadius="6" x:Name="bg">
                                                                            <TextBlock Text="🔄" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="bg" Property="Background" Value="#30363D"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>

                                                <!-- Delete -->
                                                <Button Command="{Binding DataContext.DeleteUserCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Kullanıcıyı Sil" Cursor="Hand"
                                                        Width="32" Height="32">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border Background="Transparent" CornerRadius="6" x:Name="bg">
                                                                            <TextBlock Text="🗑️" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="bg" Property="Background" Value="#3D1F1F"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Loading Overlay -->
                    <Border Grid.Row="2" Background="#800D1117" CornerRadius="8"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="⏳ Yükleniyor..." FontSize="16" Foreground="#8B949E"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
