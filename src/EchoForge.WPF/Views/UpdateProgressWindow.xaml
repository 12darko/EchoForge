<Window x:Class="EchoForge.WPF.Views.UpdateProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="EchoForge Update" 
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Width="500" Height="300" ShowInTaskbar="False" Topmost="True">

    <Window.Resources>
        <Storyboard x:Key="FadeIn">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
        </Storyboard>
    </Window.Resources>

    <Window.Triggers>
        <EventTrigger RoutedEvent="Window.Loaded">
            <BeginStoryboard Storyboard="{StaticResource FadeIn}"/>
        </EventTrigger>
    </Window.Triggers>

    <Grid>
        <Border Background="#CC000000" CornerRadius="16"/>

        <!-- Glass Card -->
        <Border CornerRadius="16" Margin="0" Padding="32" 
                BorderBrush="#30FFFFFF" BorderThickness="1">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#F0161B22" Offset="0"/>
                    <GradientStop Color="#E80D1117" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect Color="#8B5CF6" Opacity="0.2" BlurRadius="40" ShadowDepth="0"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
                    <TextBlock Text="⬇️" FontSize="28" VerticalAlignment="Center" Margin="0,0,14,0"/>
                    <StackPanel>
                        <TextBlock x:Name="TitleText" Text="Downloading Update..." FontSize="20" FontWeight="Bold" Foreground="#F8FAFC"/>
                        <TextBlock x:Name="VersionText" Text="" FontSize="12" Foreground="#64748B" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Progress Bar -->
                <Grid Grid.Row="1" Margin="0,0,0,12">
                    <Border Background="#15FFFFFF" CornerRadius="6" Height="12"/>
                    <Border x:Name="ProgressFill" CornerRadius="6" Height="12" HorizontalAlignment="Left" Width="0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#A855F7" Offset="0"/>
                                <GradientStop Color="#6366F1" Offset="0.5"/>
                                <GradientStop Color="#3B82F6" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                </Grid>

                <!-- Percentage -->
                <DockPanel Grid.Row="2" Margin="0,0,0,16">
                    <TextBlock x:Name="StatusText" Text="Preparing download..." 
                               FontSize="13" Foreground="#94A3B8" DockPanel.Dock="Left"/>
                    <TextBlock x:Name="PercentText" Text="0%" 
                               FontSize="14" FontWeight="Bold" Foreground="#8B5CF6" 
                               DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                </DockPanel>

                <!-- File size info -->
                <TextBlock Grid.Row="3" x:Name="DetailText" Text="" 
                           FontSize="11" Foreground="#475569" Margin="0,0,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>
