<Application x:Class="EchoForge.WPF.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:EchoForge.WPF.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/DarkTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
            <converters:InverseBoolConverter x:Key="InverseBool"/>
            <converters:StringToVisibilityConverter x:Key="StringToVisibility"/>
            <converters:StringToInverseVisibilityConverter x:Key="StringToInverseVisibility"/>
            <converters:StringMatchToVisibilityConverter x:Key="StringMatchToVisibilityConverter"/>
            <converters:IntMatchToVisibilityConverter x:Key="IntMatchToVisibility"/>
            <converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
            <converters:NullToVisibilityConverter x:Key="NullToInverseVisibility" />
            <converters:StatusVisibilityConverter x:Key="StatusVisibility"/>
            <converters:StatusToProgressConverter x:Key="StatusToProgress"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibility"/>
            <converters:DurationToWidthConverter x:Key="DurationToWidth"/>
            <converters:DurationAndZoomMultiConverter x:Key="DurationAndZoomMulti"/>
        </ResourceDictionary>
    </Application.Resources>
</Application>
