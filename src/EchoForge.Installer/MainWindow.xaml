<Window x:Class="EchoForge.Installer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:EchoForge.Installer"
        mc:Ignorable="d"
        Title="EchoForge - Kurulum" Height="400" Width="600"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#A855F7" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Height" Value="40" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="8" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#9333EA" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#374151" />
                    <Setter Property="Foreground" Value="#9CA3AF" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#0D0F1A" CornerRadius="12" BorderBrush="#1F2937" BorderThickness="1">
        <Grid>
            <!-- Close Button -->
            <Button HorizontalAlignment="Right" VerticalAlignment="Top" Width="30" Height="30" Margin="10" 
                    Background="Transparent" BorderThickness="0" Foreground="#9CA3AF" FontSize="16"
                    Content="✕" Click="CloseButton_Click" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="15" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Button.Template>
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <StackPanel Margin="40" VerticalAlignment="Center">
                
                <TextBlock Text="⚡ EchoForge" FontSize="32" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10" />
                <TextBlock Text="AI Content Studio v2.0" FontSize="16" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,0,0,30" />

                <!-- Welcome Screen -->
                <StackPanel Visibility="{Binding IsWelcomeVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="Bilgisayarınıza en yeni tam otomatik AI içerik stüdyosunu kurmak üzeresiniz." 
                               Foreground="#D1D5DB" TextWrapping="Wrap" TextAlignment="Center" Margin="0,0,0,20" FontSize="14"/>
                    
                    <TextBlock Text="Kurulum Yolu:" Foreground="#9CA3AF" Margin="0,0,0,5" />
                    <Border Background="#111827" BorderBrush="#374151" BorderThickness="1" CornerRadius="6" Height="40" Margin="0,0,0,20">
                        <TextBox Text="{Binding InstallPath, UpdateSourceTrigger=PropertyChanged}" 
                                 Background="Transparent" Foreground="White" BorderThickness="0" VerticalAlignment="Center" Padding="10,0" />
                    </Border>
                    
                    <CheckBox Content="Masaüstü kısayolu oluştur" IsChecked="{Binding CreateDesktopShortcut}" Foreground="#D1D5DB" Margin="0,0,0,20" />

                    <Button Content="Uygulamayı Kur" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding InstallCommand}" Width="200" HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Installing Screen -->
                <StackPanel Visibility="{Binding IsInstallingVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="{Binding StatusText}" Foreground="White" HorizontalAlignment="Center" FontSize="14" Margin="0,0,0,15" />
                    
                    <Border CornerRadius="6" Height="10" Background="#111827" Margin="0,0,0,20" ClipToBounds="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="{Binding ProgressValue, Converter={StaticResource PercentageToGridLengthConverter}}" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#A855F7" Grid.Column="0" CornerRadius="6,0,0,6" />
                        </Grid>
                    </Border>
                    
                    <TextBlock Text="Lütfen bekleyin..." Foreground="#9CA3AF" HorizontalAlignment="Center" FontSize="12" />
                </StackPanel>

                <!-- Done Screen -->
                <StackPanel Visibility="{Binding IsDoneVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="✅ Kurulum Başarıyla Tamamlandı!" FontSize="20" FontWeight="SemiBold" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,0,0,10" />
                    <TextBlock Text="EchoForge içerik stüdyosu kullanıma hazır." Foreground="#D1D5DB" HorizontalAlignment="Center" Margin="0,0,0,30" />
                    
                    <Button Content="Zirveye Ulaş (Başlat)" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding LaunchCommand}" Width="200" HorizontalAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
